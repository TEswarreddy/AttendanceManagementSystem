PORT=5000
NODE_ENV=development

# Database configuration (MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority&appName=<appName>
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT configuration
JWT_SECRET=<jwt-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<jwt-refresh-secret>
JWT_REFRESH_EXPIRES_IN=7d

# Redis configuration
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=<redis-password>

# Email configuration (Nodemailer / SendGrid compatible)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<sendgrid-api-key>
FROM_EMAIL=<from-email>
EMAIL_REPLY_TO=<reply-to-email>
SENDGRID_SENDER=<verified-sender-email>
SENDGRID_REPLY_TO=<reply-to-email>

# SMS configuration (Twilio)
TWILIO_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_PHONE=<twilio-phone>

# Application configuration
ATTENDANCE_THRESHOLD=75
MAX_EDIT_WINDOW_HOURS=24
FRONTEND_URL=http://localhost:5173
