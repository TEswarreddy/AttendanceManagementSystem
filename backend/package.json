{
  "name": "attendance-management-backend",
  "version": "1.0.0",
  "description": "Node.js Express backend for a B.Tech Attendance Management System",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "node src/config/seeder.js",
    "db:clear": "node src/config/clearData.js",
    "admin:create": "node src/config/createAdmin.js",
    "lint": "eslint .",
    "test:unit": "jest --runInBand --coverage --testPathPatterns=tests/unit",
    "test:api": "jest --runInBand --coverage --testPathPatterns=tests/api",
    "test:integration": "jest --runInBand --coverage --testPathPatterns=tests/integration",
    "test:db": "jest --runInBand --coverage --testPathPatterns=tests/database",
    "test:all": "npm run test:unit && npm run test:api && npm run test:integration && npm run test:db"
  },
  "keywords": [
    "attendance",
    "btech",
    "express",
    "nodejs",
    "sequelize",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.22.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.2",
    "twilio": "^5.13.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.37.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4"
  }
}
